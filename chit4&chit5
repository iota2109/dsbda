import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

# 1. Load the Facebook dataset (Assignment 2)
df_fb = pd.read_csv('dataset_Facebook.csv', sep=';')

# 2. Clean the data (Fixing the median error)
# We use numeric_only=True to avoid the TypeError with text columns
df_fb = df_fb.fillna(df_fb.median(numeric_only=True))
df_fb['Type'] = df_fb['Type'].fillna(df_fb['Type'].mode()[0])

//cell8
plt.figure(figsize=(8,5))
sns.countplot(data=df_fb, x='Type', palette='viridis')
plt.title('Frequency of Facebook Post Types')
plt.show()

//cell9
plt.figure(figsize=(8,5))
sns.scatterplot(data=df_fb, x='Page total likes', y='like', hue='Type')
plt.title('Page Total Likes vs. Individual Post Likes')
plt.show()

//cell10
plt.figure(figsize=(12,8))
sns.heatmap(df_fb.select_dtypes(include=['float64', 'int64']).corr(), cmap='magma', annot=False)
plt.title('Correlation Matrix of Facebook Metrics')
plt.show()
