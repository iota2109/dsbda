# 1. Drop every column that has ANY missing values (The Purge)
df_heart = pd.read_csv('heart_disease_uci.csv', sep=';', decimal=',')
df_heart_clean = df_heart.dropna(axis=1)

# 2. Verify - this will only show columns that were already perfect
print("Cleaned Columns:", df_heart_clean.columns.tolist())
print(df_heart_clean.isnull().sum())

# 3. Integration - Merge the clean Heart data with your Air data
import pandas as pd
integrated_df = pd.concat([df_air.head(), df_heart_clean.head()], axis=0)

print("--- INTEGRATION COMPLETE ---")

//cell6
# 1. Take a small slice from each (the first 5 rows)
# This prevents the final table from being a giant, unreadable mess
air_slice = df_air.head()
heart_slice = df_heart_clean.head()

# 2. Integrate them (Stacking them)
# axis=0 stacks them vertically
# ignore_index=True resets the row numbers to 0, 1, 2...
integrated_df = pd.concat([air_slice, heart_slice], axis=0, ignore_index=True)

# 3. Prove it worked
print("--- INTEGRATED DATASET PREVIEW ---")
print(integrated_df)

print("\n--- FINAL VERIFICATION ---")
print("Total rows:", len(integrated_df))
print("Total columns in integrated set:", len(integrated_df.columns))

